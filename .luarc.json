    "add_linkdirs",
    "add_defines",
    "add_cflags",
    "add_cxxflags",
    "add_ldflags",
    "add_files",
    "add_headerfiles",
    "add_tests",
    "add_packages",
    "add_deps",
    "add_options",
    "add_moduledirs",
    "target",
    "target_end",
    "set_kind",
    "set_default",
    "set_targetdir",
    "option",
    "option_end",
    "task",
    "task_end",
    "set_menu",
    "on_run",
    "on_load",
    "on_build",
    "on_install",
    "before_build",
    "after_build",
